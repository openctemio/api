# Agent Configuration for {{.Agent.Name}}
# Generated by OpenCTEM at {{.GeneratedAt}}
#
# Edit /app/configs/agent-templates/yaml.tmpl on the API host to customize
# this template — no frontend rebuild needed.

agent:
  name: {{.Agent.Name}}
  region: "{{.Agent.Region}}"  # Optional: deployment region for monitoring
  enable_commands: true
  command_poll_interval: 30s
  heartbeat_interval: 1m

server:
  base_url: {{.BaseURL}}
  api_key: {{.APIKey}}
  agent_id: {{.Agent.ID}}

scanners:
{{- if .Agent.Tools}}
{{- range .Agent.Tools}}
  - name: {{toScannerName .}}
    enabled: true
{{- end}}
{{- else}}
  - name: semgrep
    enabled: true
{{- end}}

# Optional: Default scan targets (for standalone mode)
# targets:
#   - /path/to/project1
#   - /path/to/project2
